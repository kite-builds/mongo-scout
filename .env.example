# Copy to .env and fill in. The .env file is gitignored.

# Required for a live query (free key from https://aistudio.google.com/apikey).
GEMINI_API_KEY=

# MongoDB the agent triages. Atlas free tier works:
#   mongodb+srv://USER:PASS@cluster0.xxxx.mongodb.net/
MDB_MCP_CONNECTION_STRING=

# Optional overrides:
# MONGO_SCOUT_MODEL=gemini-2.0-flash
# MONGO_SCOUT_READONLY=true
